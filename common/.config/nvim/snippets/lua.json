{
  "Lua function": {
    "prefix": "fun",
    "body": "function ${1:name}(${2:args})\n\t$0\nend",
    "desc": "function definition"
  },
  "Lua anonymous function": {
    "prefix": "fn",
    "body": "function(${1:args}) $0 end",
    "desc": "Anonymous function"
  },
  "Lua for loop": {
    "prefix": "for",
    "body": "for ${1:i} = ${2:1}, ${3:10} do\n\t$0\nend",
    "desc": "for loop"
  },
  "Lua for pairs": {
    "prefix": "fp",
    "body": "for ${1:k}, ${2:v} in pairs(${3:table}) do\n\t$0\nend",
    "desc": "for pairs loop"
  },
  "Lua for ipairs": {
    "prefix": "fip",
    "body": "for ${1:i}, ${2:v} in ipairs(${3:table}) do\n\t$0\nend",
    "desc": "for ipairs loop"
  },
  "Lua if": {
    "prefix": "if",
    "body": "if ${1:cond} then\n\t$0\nend",
    "desc": "if block"
  },
  "Lua if/else": {
    "prefix": "ife",
    "body": "if ${1:cond} then\n\t$2\nelse\n\t$0\nend",
    "desc": "if/else block"
  },
  "Lua table": {
    "prefix": "tbl",
    "body": "{\n\t$1,\n\t$0\n}",
    "desc": "table literal"
  },
  "Lua local": {
    "prefix": "loc",
    "body": "local ${1:name} = ${2:value}$0",
    "desc": "local variable"
  },
  "Lua require": {
    "prefix": "req",
    "body": "local ${1:name} = require(\"${2:module}\")$0",
    "desc": "require module"
  },
  "Lua return": {
    "prefix": "ret",
    "body": "return ${1:value}$0",
    "desc": "return statement"
  },
  "Lua vim.keymap.set": {
    "prefix": "map",
    "body": "vim.keymap.set(\"${1:n}\", \"${2:keys}\", ${3:action}, { desc = \"$0\" })",
    "desc": "vim.keymap.set"
  },
  "Lua vim.opt": {
    "prefix": "opt",
    "body": "vim.opt.${1:name} = ${2:value}$0",
    "desc": "vim.opt"
  },
  "Lua vim.api.nvim_create_autocmd": {
    "prefix": "autocmd",
    "body": "vim.api.nvim_create_autocmd(\"${1:Event}\", {\n\tpattern = \"${2:*}\",\n\tcallback = function()\n\t\t$0\n\tend,\n})",
    "desc": "vim.api.nvim_create_autocmd"
  },
  "Lua print debug": {
    "prefix": "pd",
    "body": "print(vim.inspect(${1:var}))$0",
    "desc": "print(vim.inspect()) debug"
  }
}
