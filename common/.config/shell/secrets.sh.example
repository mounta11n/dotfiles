# ———————————————————————————————
#  secrets.sh — API Keys & Secrets
# ———————————————————————————————
# Kopiere diese Datei nach ~/.config/shell/secrets.sh
# und trage deine Secrets ein.
#
# WICHTIG:
#   • Diese Datei steht in .gitignore und wird NIEMALS committed.
#   • Um sie sicher zu verteilen: dotsec lock  (verschlüsselt mit age)
#   • Auf einem neuen Gerät:    dotsec unlock (nach git pull)
#
# Einrichtung (einmalig pro Gerät):
#   1) dotsec setup             → erzeugt age-Schlüsselpaar
#   2) age Identity sichern     → z.B. in 1Password / Passwort-Manager
#   3) dotsec lock              → verschlüsselt und pusht
#
# Workflow bei Änderungen:
#   1) ~/.config/shell/secrets.sh bearbeiten
#   2) dotsec lock              → verschlüsselt, committed, gepusht
#
# Workflow auf neuem Gerät:
#   1) git pull
#   2) dotsec unlock            → entschlüsselt nach ~/.config/shell/secrets.sh
#
# ---------------------------------------------------------------

# Beispiel-Variablen (anpassen oder löschen):
# export OPENAI_API_KEY="sk-..."
# export ANTHROPIC_API_KEY="sk-ant-..."
