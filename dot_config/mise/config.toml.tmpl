# ---------------------------------------------------------------------------
# Tasks — install tool groups on demand
# ---------------------------------------------------------------------------

[tasks."runtime-tools"]
description = "Core runtimes & languages"
run = '''
mise install bun ccache cmake go gum java lua luajit node rust uv perl
'''

[tasks."dev-tools"]
description = "DevOps, infrastructure & development tools"
run = '''
mise install age ast-grep chezmoi coredns gh glab glow hcloud jq mdbook neovim protobuf shellcheck tree-sitter yq
'''

[tasks."cli-tools"]
description = "CLI enhancements (pagers, launchers, prompts)"
run = '''
mise install bat bat-extras bottom fd fzf lsd ripgrep starship tlrc usage vivid yazi
'''

[tasks."system-tools"]
description = "System & network utilities"
run = '''
mise install ctop curlie duf dust fastfetch gping grpcurl httpie-go killport portless qdns
'''

[tasks."lazy-tools"]
description = "Lazy* TUI suite (lazydocker, lazygit, lazyjournal, lazyssh)"
run = '''
mise install lazydocker lazygit lazyjournal lazyssh
'''

{{ if eq .chezmoi.os "darwin" -}}
[tasks."macos-tools"]
description = "macOS-specific tools (colima, lima, mas, tart)"
run = '''
mise install colima lima mas tart
'''
{{ end }}

[tasks."bootstrap:agent-tools"]
description = "Install all AI agent CLIs (mise-managed + uv-based + bun-based)"
run = '''
mise install aichat claude copilot crush gemini-cli opencode pi 2>/dev/null || true

# Install uv-based agents
uv tool install --force kimi-cli
uv tool install --force mistral-vibe

# Install bun-based agents
bun install -g little-coder
'''

[tasks."bootstrap:ml-tools"]
description = "Install local LLM tools (requires sufficient RAM/GPU)"
run = '''
mise install micromamba llmfit "llama.cpp" 2>/dev/null || true
'''

[tasks."bootstrap:misc-tools"]
description = "Install more useful and funny stuff"
run = '''
mise install astro cowsay imagemagick mermaid-ascii oha typst vhs yt-dlp 2>/dev/null || true
'''

[tasks."bootstrap:hardware-tools"]
description = "Install arduino, esp32, rpi, etc. stuff"
run = '''
mise install arduino-cli 2>/dev/null || true
'''

# ---------------------------------------------------------------------------
# Shell aliases
# ---------------------------------------------------------------------------
[shell_alias]
install-runtime-tools  = "mise run runtime-tools"
install-dev-tools      = "mise run dev-tools"
install-cli-tools      = "mise run cli-tools"
install-system-tools   = "mise run system-tools"
install-lazy-tools     = "mise run lazy-tools"
install-agent-tools    = "mise run bootstrap:agent-tools"
install-ml-tools       = "mise run bootstrap:ml-tools"
install-misc-tools     = "mise run bootstrap:misc-tools"
install-hardware-tools = "mise run bootstrap:hardware-tools"
{{ if eq .chezmoi.os "darwin" -}}
install-macos-tools    = "mise run macos-tools"
{{ end }}

# ---------------------------------------------------------------------------
# Settings
# ---------------------------------------------------------------------------
[settings]
idiomatic_version_file_enable_tools = ["bun", "go", "java", "node", "rust"]
status.show_tools = true
not_found_auto_install = true
jobs = 4
experimental = true
